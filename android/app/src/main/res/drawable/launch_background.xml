<?xml version="1.0" encoding="utf-8"?>
<!-- HMusic 启动屏幕 - 纯色背景 + 居中 Logo -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 纯色背景 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0B0B14" />
        </shape>
    </item>

    <item
        android:width="240dp"
        android:height="88dp"
        android:gravity="center">
        <inset
            android:drawable="@drawable/app_logo_vector"
            android:inset="10%" />
    </item>
</layer-list>
