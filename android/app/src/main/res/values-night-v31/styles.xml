<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12 (API 31) 及以上版本的启动屏幕配置 -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <!-- 背景色 -->
        <item name="android:windowSplashScreenBackground">#090E17</item>
        <!-- 启动图标 - 使用修正后的正方形容器矢量图，防止拉伸 -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/app_logo_vector</item>
        <!-- 显示时长（可选，用于保持兼容性） -->
        <item name="android:windowSplashScreenAnimationDuration">200</item>
        
        <!-- 基础配置 -->
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">#090E17</item>
    </style>
</resources>